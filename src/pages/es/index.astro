---
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import About from "../../components/About.astro";
import Highlights from "../../components/Highlights.astro";
import CaseStudies from "../../components/CaseStudies.astro";
import Projects from "../../components/Projects.astro";
import Experience from "../../components/Experience.astro";
import Education from "../../components/Education.astro";
import Footer from "../../components/Footer.astro";
import { configs } from "../../config";
import "../../styles/global.css";

const lang = "es" as const;
const siteConfig = configs[lang];
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={siteConfig.description} />
    <link rel="alternate" hreflang="en" href="https://wendyrodrich.cofoundy.dev/" />
    <link rel="alternate" hreflang="es" href="https://wendyrodrich.cofoundy.dev/es/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Source+Sans+3:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{siteConfig.name} - {siteConfig.title}</title>
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <Hero lang={lang} />
      <About lang={lang} />
      <Highlights lang={lang} />
      <CaseStudies lang={lang} />
      <Projects lang={lang} />
      <Experience lang={lang} />
      <Education lang={lang} />
    </main>
    <Footer lang={lang} />

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const delay = parseInt((entry.target as HTMLElement).style.transitionDelay) || 0;
              setTimeout(() => {
                entry.target.classList.add("revealed");
              }, delay);
              observer.unobserve(entry.target);
            }
          });
        },
        { root: null, rootMargin: "0px 0px -80px 0px", threshold: 0.05 }
      );

      document.querySelectorAll(".fade-in").forEach((el) => {
        observer.observe(el);
      });

      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
          e.preventDefault();
          const target = document.querySelector((this as HTMLAnchorElement).getAttribute('href')!);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
    </script>
  </body>
</html>
