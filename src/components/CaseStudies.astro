---
import { siteConfig } from "../config";
const hasCaseStudies = siteConfig.caseStudies && siteConfig.caseStudies.length > 0;
---

{hasCaseStudies && (
  <>
    <div class="w-full h-1 accent-bar-shimmer" style={`background: linear-gradient(90deg, ${siteConfig.accentColor} 0%, ${siteConfig.highlightColor} 50%, ${siteConfig.accentColor} 100%)`}></div>

    <section id="case-studies" class="py-12 md:py-16 bg-white">
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div class="mb-10 fade-in">
          <h2 class="text-3xl md:text-4xl font-bold" style={`color: ${siteConfig.accentColor}`}>Marketing Results & Case Studies</h2>
          <div class="w-16 h-1 mt-3 rounded-full" style={`background-color: ${siteConfig.highlightColor}`}></div>
        </div>

        <div class="grid grid-cols-1 gap-8">
          {siteConfig.caseStudies.map((cs, index) => (
            <div
              class="fade-in p-6 md:p-8 rounded-xl bg-gray-50"
              style={`border: 1px solid ${siteConfig.accentColor}15; transition-delay: ${index * 150}ms`}
            >
              <div class="flex items-start gap-4 mb-4">
                <div
                  class="w-10 h-10 rounded-lg flex items-center justify-center text-sm font-bold flex-shrink-0"
                  style={`background-color: ${siteConfig.highlightColor}20; color: ${siteConfig.highlightColor}`}
                >
                  0{index + 1}
                </div>
                <h3 class="text-xl font-semibold" style={`color: ${siteConfig.accentColor}`}>
                  {cs.name}
                </h3>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-4">
                <div>
                  <h4 class="text-sm font-semibold uppercase tracking-wider mb-2" style={`color: ${siteConfig.highlightColor}`}>Objective</h4>
                  <p class="text-sm text-gray-600 leading-relaxed">{cs.objective}</p>
                </div>
                <div>
                  <h4 class="text-sm font-semibold uppercase tracking-wider mb-2" style={`color: ${siteConfig.highlightColor}`}>Strategy</h4>
                  <p class="text-sm text-gray-600 leading-relaxed">{cs.strategy}</p>
                </div>
                <div>
                  <h4 class="text-sm font-semibold uppercase tracking-wider mb-2" style={`color: ${siteConfig.highlightColor}`}>Results</h4>
                  <ul class="space-y-1">
                    {cs.results.map((result) => (
                      <li class="text-sm text-gray-600 flex items-start gap-2">
                        <span class="mt-1.5 w-1.5 h-1.5 rounded-full flex-shrink-0" style={`background-color: ${siteConfig.highlightColor}`}></span>
                        {result}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </>
)}
